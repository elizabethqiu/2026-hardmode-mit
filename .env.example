# Enoki — Environment Variables
# Copy to .env and fill in values

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=512
CLAUDE_INTERVAL_SECONDS=900
MIN_CLAUDE_INTERVAL=60

# ── Serial (auto-detect by OS if not set) ──────────────────────────────────────
# Linux: /dev/ttyUSB0, /dev/ttyUSB1
# Windows: COM3, COM4
# macOS: /dev/cu.usbserial-*
XIAO_PORT=
ARDUINO_PORT=
BAUD=115200

# ── Vision ───────────────────────────────────────────────────────────────────
CAMERA_INDEX=0
FPS_TARGET=10
MEDIAPIPE_DETECTION_CONFIDENCE=0.5
MEDIAPIPE_TRACKING_CONFIDENCE=0.5

# ── TTS ───────────────────────────────────────────────────────────────────────
# auto | piper | espeak | none
TTS_BACKEND=auto
PIPER_MODEL_PATH=/home/pi/tts_models/en_US-lessac-medium.onnx

# ── Paths (relative to project root) ────────────────────────────────────────────
DB_PATH=data/enoki.db
MODEL_PATH=models/focus_pattern.pkl

# ── Supabase / Grove Network ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
USER_ID=
GROVE_ID=

# ── Glasses Receiver ──────────────────────────────────────────────────────────
GLASSES_RECEIVER_PORT=8420
GLASSES_RECEIVER_HOST=0.0.0.0

# ── State Machine Thresholds (seconds) ────────────────────────────────────────
DOZING_NUDGE_THRESHOLD=90
IDLE_NUDGE_THRESHOLD=300
FOCUSED_BREAK_THRESHOLD=1500
AWAY_SLEEP_THRESHOLD=600
